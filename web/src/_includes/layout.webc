<!DOCTYPE html>
<html lang="en" style="color-scheme: light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title @text="title" webc:keep></title>

    <script @raw="`const API_BASE = '${site.apiBase}';`" webc:keep>
      const FETCH_OPTS = { credentials: "include" };
    </script>

    <link rel="stylesheet" href="/vendor/maplibre-gl.css" webc:keep />
    <link rel="stylesheet" href="/style.css" webc:keep />
    <style @raw="getBundle('css')" webc:keep></style>
  </head>
  <body>
    <page-header
      :login-href="page.url === '/' ? '#login' : '/login'"
    ></page-header>
    <msg-banner>
      <span slot="summary">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path stroke="none" d="M0 0h24v24H0z" />
          <path
            d="M12 9v4M10.363 3.591 2.257 17.125a1.914 1.914 0 0 0 1.636 2.871h16.214a1.914 1.914 0 0 0 1.636-2.87L13.637 3.59a1.914 1.914 0 0 0-3.274 0M12 16h.01"
          />
        </svg>
        This is a work-in-progress. Functionality is limited and things will be
        broken.</span
      >
      <div slot="message">
        <p>
          Activity data is public. This saves activities with location data to a
          PDS which is accessible to the world.
        </p>
      </div>
    </msg-banner>
    <main @raw="content"></main>
    <page-footer></page-footer>

    <script src="/vendor/maplibre-gl.js" webc:keep></script>
    <script src="/app.js" webc:keep></script>
    <script @raw="getBundle('js', 'components')" webc:keep></script>
  </body>
</html>
