<!DOCTYPE html>
<html lang="en" style="color-scheme: light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title @text="title" webc:keep></title>

    <script @raw="`const API_BASE = '${site.apiBase}';`" webc:keep>
      const FETCH_OPTS = { credentials: "include" };
    </script>

    <link rel="stylesheet" href="/style.css" webc:keep />
    <style @raw="getBundle('css')" webc:keep></style>
  </head>
  <body>
    <page-header :login-href="page.url === '/' ? '#login' : '/login'"></page-header>
    <main @raw="content"></main>

    <script src="/app.js" webc:keep></script>
    <script @raw="getBundle('js', 'components')" webc:keep></script>
  </body>
</html>
