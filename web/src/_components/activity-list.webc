    if (article) article.remove();
  } catch (err) {
    alert("Delete failed: " + err.message);
    btn.disabled = false;
    btn.textContent = "Delete";
  }
}
  */
</script>

<style webc:scoped>
  :host {
    display: block;
  }

  ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    row-gap: 1.25rem;
  }

  .activity {
    border: 1px dotted color-mix(in srgb, currentColor 20%, transparent);
    border-radius: 20px;
    overflow: hidden;
  }

  .activity-header {
    padding: 1.5rem;

    time {
      display: block;
      font-size: 0.875rem;
      line-height: 1;
    }

    a {
      font-weight: 600;
      font-size: 1.5rem;
    }
  }

  .activity-stats {
    display: flex;
    flex-wrap: wrap;
    padding-top: 1rem;
    max-width: 50ch;
    column-gap: 0.5rem;
    row-gap: 1rem;

    > div {
      flex: 1;
      min-width: 10ch;
    }

    .stat-label {
      font-size: 0.875rem;
      line-height: 1;
    }

    .stat-value {
      font-size: 1.125rem;
      font-weight: 600;
      line-height: 1.1;
    }
  }

  .activity-map {
    background: color-mix(in srgb, currentColor 5%, transparent);
    overflow: hidden;

    p {
      padding: 8rem 3rem;
      opacity: 0.5;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
  }
</style>
