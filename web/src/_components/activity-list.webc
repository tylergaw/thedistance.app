<script webc:bucket="components">
  class ActivityList extends HTMLElement {
    connectedCallback() {
      if (this.loading) {
        this.insertAdjacentHTML(
          "beforeend",
          `<p class="loading-indicator">Looking for <s>love</s>activities in all the wrong places…</p>`
        );
      }
    }

    get editable() {
      return this.hasAttribute("editable");
    }

    set editable(value) {
      if (value) {
        this.setAttribute("editable", "");
      } else {
        this.removeAttribute("editable");
      }
    }

    get loading() {
      return this.hasAttribute("loading");
    }

    set loading(value) {
      if (value) {
        this.setAttribute("loading", "");
      } else {
        this.removeAttribute("loading");
        this.querySelector(".loading-indicator").remove();
      }
    }

    set activities(data) {
      this.loading = false;

      if (data.length === 0) {
        this.insertAdjacentHTML("beforeend", "<p>No Activities yet</p>");
        return;
      }

      // https://bsky.app/profile/jamellebouie.net/post/3mjkzfkmvvs2g
      const activitiesHTML = `
      <ul>
        ${data
          .map((activity) => {
            const stats = [
              {
                label: "Distance",
                value: `${metersToMiles(activity.distance)} mi`,
              },
              {
                label: "Moving Time",
                value: `${formatDuration(activity.moving_time)}`,
              },
              {
                label: "Elev Gain",
                value: `${metersToFeet(activity.elevation_gain)} ft`,
              },
            ];

            return `<li>
              <div class="activity" id="activity-${activity.rkey}">
                <header class="activity-header">
                  <time>${formatDate(activity.started_at)}</time>

                  <a href="/profile/${activity.did}/activities/${
              activity.rkey
            }">${
              activity.title ||
              `Untitled ${getActivityTypeDisplayName(activity.sport_type)}`
            }</a>
                <div class="activity-stats">
                  ${stats
                    .map((s) => {
                      return `
                        <div>
                          <div class="stat-label">${s.label}</div>
                          <div class="stat-value">${s.value}</div>
                        </div>`;
                    })
                    .join("")}
                </div>
              </header>

              <div class="activity-map">
                <p><b>Map here soon:</b> ${activity.polyline}</p>
              </div>
            </div>
          </li>`;
          })
          .join("")}
      </ul>`;

      this.insertAdjacentHTML("beforeend", activitiesHTML);
      console.log(data);
    }
  }

  customElements.define("activity-list", ActivityList);

  /*
