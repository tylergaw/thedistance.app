<h2>Upload Activities</h2>
<p>Supported formats: FIT</p>
<form id="upload-form">
  <input type="file" id="file-input" accept=".fit" multiple />
  <button type="submit">Upload</button>
</form>
<div id="upload-error"></div>
<div id="preview"></div>
